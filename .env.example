APP_ENV=production
APP_NAME=riads-api
API_BASE_URL=https://api.riads.shop
FRONTEND_URL=https://riads.shop
CORS_ORIGINS=https://riads.shop,https://www.riads.shop

DATABASE_URL=postgres://riads:riads@riads_database:5432/riads?sslmode=disable
RUN_MIGRATIONS_ON_START=true

# Google Sheets — pick ONE method:
# A) Service account (recommended): share sheet with SA email, paste base64 from scripts/encode-service-account.py
GOOGLE_SHEETS_SPREADSHEET_ID=1noCh6q_Q-G-fnFWUoPdiHJ7aVL-9r2BMdHTI2xrVl1I
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# B) Apps Script web app URL ending in /exec
GOOGLE_SHEETS_WEBHOOK_URL=

META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

HASH_SALT_INTERNAL=
ENABLE_CAPI=true
ENABLE_SHEETS_WEBHOOK=true
LOG_LEVEL=INFO

# MaxMind GeoIP2 Insights — order fraud / geo restriction
# Sign up at https://www.maxmind.com/ → Account → Manage License Keys
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ENABLE_GEO_RESTRICTION=true
ALLOWED_COUNTRIES=MA
BLOCK_VPN=true
BLOCK_TOR=true
BLOCK_HOSTING=true
# If true, orders are allowed when MaxMind is unreachable (fail-open).
# Set to false to block orders when MaxMind lookup fails (fail-closed, stricter).
GEO_FAIL_OPEN=true

# IPQualityScore — optional second VPN/proxy check (https://www.ipqualityscore.com)
IPQS_API_KEY=
IPQS_STRICTNESS=1

# Admin dashboard (required for /admin API)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_TOKEN_TTL_HOURS=24
